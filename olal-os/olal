#!/data/data/com.termux/files/usr/bin/bash
# ============================================================
#  Olal OS - boota DIRETO na interface do Olal (o OS em si),
#  rodando sobre o Debian, no Termux:X11, com GPU da Adreno.
#  A interface do Olal E o sistema - nao e um launcher.
# ============================================================

# 0) AUTO-ATUALIZA do GitHub e PREPARA o deploy num /tmp compartilhado.
SRC="$HOME/Olal"
DEPLOY="$TMPDIR/olal-deploy"
( if [ -d "$SRC/.git" ]; then
    echo ">> Procurando atualizacoes do Olal OS..."
    if ( cd "$SRC" && timeout 30 git fetch origin main >/dev/null 2>&1 \
          && git reset --hard origin/main >/dev/null 2>&1 ); then
      echo ">> Atualizado para: $(cd "$SRC" && git log -1 --format='%h %s' 2>/dev/null)"
    else
      echo "!! Nao consegui baixar a atualizacao (rede/VPN?). Usando a versao local."
      echo "   Dica: desligue a VPN e rode de novo, ela bloqueia o GitHub."
    fi
  fi ) || true
# stage dos arquivos no /tmp compartilhado (sempre visivel dentro do proot)
rm -rf "$DEPLOY" 2>/dev/null; mkdir -p "$DEPLOY"
cp -rf "$SRC/olal-os/shell"           "$DEPLOY/shell"      2>/dev/null
cp -f  "$SRC/olal-os/desktop/olal-shell"  "$DEPLOY/olal-shell"  2>/dev/null
cp -f  "$SRC/olal-os/desktop/olal-webkit" "$DEPLOY/olal-webkit" 2>/dev/null
cp -f  "$SRC/olal-os/desktop/olal-gpu-boost" "$DEPLOY/olal-gpu-boost" 2>/dev/null
cp -f  "$SRC/olal-os/desktop/olal-rc.xml"  "$DEPLOY/olal-rc.xml" 2>/dev/null
cp -f  "$SRC/olal-os/desktop/olal-tint2rc" "$DEPLOY/olal-tint2rc" 2>/dev/null
grep -o 'OLAL_BUILD = "[^"]*"' "$DEPLOY/shell/index.html" 2>/dev/null \
  | sed 's/OLAL_BUILD = />> Versao que vai ser instalada: /'
# cinto-e-suspensorio: tambem tenta copiar direto pro rootfs (varios caminhos
# possiveis do proot-distro). Se um bater, ja atualiza; senao, o /tmp resolve.
for RD in \
  "$PREFIX/var/lib/proot-distro/installed-rootfs/debian" \
  "$HOME/.proot-distro/installed-rootfs/debian" \
  /data/data/com.termux/files/usr/var/lib/proot-distro/installed-rootfs/debian; do
  if [ -d "$RD" ]; then
    mkdir -p "$RD/opt/olal/shell" "$RD/root/.config/openbox" "$RD/root/.config/tint2" "$RD/etc/olal" 2>/dev/null
    cp -rf "$DEPLOY/shell/." "$RD/opt/olal/shell/" 2>/dev/null \
      && cp -f "$DEPLOY/olal-shell" "$RD/usr/local/bin/olal-shell" 2>/dev/null \
      && chmod +x "$RD/usr/local/bin/olal-shell" 2>/dev/null
    [ -f "$DEPLOY/olal-webkit" ] && cp -f "$DEPLOY/olal-webkit" "$RD/usr/local/bin/olal-webkit" 2>/dev/null && chmod +x "$RD/usr/local/bin/olal-webkit" 2>/dev/null
    [ -f "$DEPLOY/olal-gpu-boost" ] && cp -f "$DEPLOY/olal-gpu-boost" "$RD/usr/local/bin/olal-gpu-boost" 2>/dev/null && chmod +x "$RD/usr/local/bin/olal-gpu-boost" 2>/dev/null
    # tambem espalha as config do WM/barra (pro caso de setup-desktop nao ter rodado ainda)
    [ -f "$DEPLOY/olal-rc.xml" ] && cp -f "$DEPLOY/olal-rc.xml" "$RD/root/.config/openbox/rc.xml" 2>/dev/null
    [ -f "$DEPLOY/olal-tint2rc" ] && cp -f "$DEPLOY/olal-tint2rc" "$RD/root/.config/tint2/tint2rc" 2>/dev/null
    echo ">> (copia direta ok em $RD)"
  fi
done

# 1) audio (PulseAudio) - SOBE SOB DEMANDA. Mantemos o servidor em pe se o
#    usuario ja esta ouvindo algo, mas auto-exit apos 30s idle pra nao gastar
#    CPU. Se ja esta rodando, nao reinicia.
if ! pgrep -x pulseaudio >/dev/null 2>&1; then
  pulseaudio --start \
    --load="module-native-protocol-tcp auth-ip-acl=127.0.0.1 auth-anonymous=1" \
    --exit-idle-time=30 2>/dev/null || true
fi

# 2) servidor GPU (virgl) ACELERADO POR HARDWARE -- TEM que subir ANTES do X.
pkill -f virgl_test_server 2>/dev/null
rm -f "$TMPDIR/olal-gpu" 2>/dev/null
if command -v virgl_test_server >/dev/null 2>&1; then
  echo ">> GPU: virgl acelerado por zink/Turnip (Adreno)."
  MESA_LOADER_DRIVER_OVERRIDE=zink GALLIUM_DRIVER=zink ZINK_DESCRIPTORS=lazy \
  MESA_NO_ERROR=1 MESA_GL_VERSION_OVERRIDE=4.3COMPAT MESA_GLES_VERSION_OVERRIDE=3.2 \
    virgl_test_server --use-egl-surfaceless >/dev/null 2>&1 &
  touch "$TMPDIR/olal-gpu" 2>/dev/null
else
  echo ">> GPU: virgl (software) -- instale virglrenderer-mesa-zink p/ acelerar."
  MESA_NO_ERROR=1 MESA_GL_VERSION_OVERRIDE=4.3COMPAT \
  MESA_GLES_VERSION_OVERRIDE=3.2 LIBGL_DRI3_DISABLE=1 \
    virgl_test_server_android >/dev/null 2>&1 &
fi

# 3) servidor de tela (Termux:X11). Sobe + abre a Activity Android.
#    PERFORMANCE: sleep reduzido (3s -> 2s); ja basta na grande maioria.
pkill -f "termux-x11 :0" 2>/dev/null
export XDG_RUNTIME_DIR="$TMPDIR"
termux-x11 :0 >/dev/null 2>&1 &
sleep 2
am start --user 0 -n com.termux.x11/com.termux.x11.MainActivity >/dev/null 2>&1 || true
sleep 1

# prioridade: rebaixa os servicos de fundo (virgl/pulseaudio) pra o NAVEGADOR
# ganhar CPU. renice +5 + ionice idle - sem root, so renice funciona.
for p in virgl_test_server virgl_test_server_android pulseaudio; do
  pgrep -x "$p" >/dev/null 2>&1 && {
    renice +5  -p $(pgrep -x "$p") >/dev/null 2>&1
    ionice -c 3 -p $(pgrep -x "$p") >/dev/null 2>&1 || true
  }
done

echo ">> Abra o app Termux:X11 para ver o Olal OS."

# RELATORIO NO TERMINAL: o boot grava cada passo em /tmp/olal-boot-report.txt
# (compartilhado). Imprime aqui no Termux ~75s depois - VISIVEL mesmo se a
# tela do X estiver preta. Se a tela ficar preta, TIRE PRINT DESTE TERMINAL.
rm -f "$TMPDIR/olal-boot-report.txt" 2>/dev/null
( sleep 75
  echo ""
  echo "========== RELATORIO DO BOOT (o que aconteceu la dentro) =========="
  cat "$TMPDIR/olal-boot-report.txt" 2>/dev/null || echo "(sem relatorio - o olal-shell nem chegou a rodar)"
  echo "===================================================================="
  echo "  Tela preta? Tire um PRINT deste terminal e mande." ) &

# 4) BOOTA o Olal OS: instala o codigo novo (de DENTRO, via /tmp compartilhado),
#    sobe o WM + a barra do Olal + a interface em tela cheia.
#    A sessao interna vira um SCRIPT em /tmp (compartilhado) e a saida e
#    CAPTURADA: se aparecer o bug do proot ("fork: Function not implemented",
#    ENOSYS - comum apos updates de Android/kernel), o boot se REINICIA
#    sozinho em modo compativel (PROOT_NO_SECCOMP=1) e memoriza a escolha.
cat > "$TMPDIR/olal-inner.sh" <<'INNER'
  # instala o codigo novo que o Termux deixou em /tmp/olal-deploy
  if [ -d /tmp/olal-deploy/shell ]; then
    mkdir -p /opt/olal/shell
    cp -rf /tmp/olal-deploy/shell/. /opt/olal/shell/
    [ -f /tmp/olal-deploy/olal-shell ] && cp -f /tmp/olal-deploy/olal-shell /usr/local/bin/olal-shell && chmod +x /usr/local/bin/olal-shell
    [ -f /tmp/olal-deploy/olal-webkit ] && cp -f /tmp/olal-deploy/olal-webkit /usr/local/bin/olal-webkit && chmod +x /usr/local/bin/olal-webkit
    [ -f /tmp/olal-deploy/olal-gpu-boost ] && cp -f /tmp/olal-deploy/olal-gpu-boost /usr/local/bin/olal-gpu-boost && chmod +x /usr/local/bin/olal-gpu-boost
    # espalha configs do WM/barra (idempotente; so reescreve se forem novas)
    if [ -f /tmp/olal-deploy/olal-rc.xml ]; then
      mkdir -p /root/.config/openbox /etc/olal
      cp -f /tmp/olal-deploy/olal-rc.xml /root/.config/openbox/rc.xml
      cp -f /tmp/olal-deploy/olal-rc.xml /etc/olal/openbox-rc.xml
    fi
    if [ -f /tmp/olal-deploy/olal-tint2rc ]; then
      mkdir -p /root/.config/tint2
      cp -f /tmp/olal-deploy/olal-tint2rc /root/.config/tint2/tint2rc
      cp -f /tmp/olal-deploy/olal-tint2rc /etc/olal/tint2rc 2>/dev/null || true
    fi
    echo ">> Olal OS instalado dentro do Debian:"
    grep -o "OLAL_BUILD = \"[^\"]*\"" /opt/olal/shell/index.html 2>/dev/null | sed "s/OLAL_BUILD = />>   versao: /"
  fi
  # ---- tuning do sistema (idempotente, barato): apt/dpkg mais rapido e leve ----
  [ -f /etc/apt/apt.conf.d/99olal ] || \
    printf "APT::Install-Recommends \"false\";\nAPT::Install-Suggests \"false\";\nAcquire::Languages \"none\";\n" > /etc/apt/apt.conf.d/99olal 2>/dev/null
  [ -f /etc/dpkg/dpkg.cfg.d/99olal-nodoc ] || \
    printf "path-exclude /usr/share/doc/*\npath-exclude /usr/share/man/*\npath-exclude /usr/share/info/*\npath-exclude /usr/share/locale/*/LC_MESSAGES/*.mo\n" > /etc/dpkg/dpkg.cfg.d/99olal-nodoc 2>/dev/null

  # ---- ambiente de GPU/render (todos os apps X11 herdam estes env) ----
  export DISPLAY=:0
  export PULSE_SERVER=127.0.0.1
  export GALLIUM_DRIVER=virpipe
  export MESA_GL_VERSION_OVERRIDE=4.3COMPAT
  export MESA_GLES_VERSION_OVERRIDE=3.2
  export MESA_NO_ERROR=1
  # shader cache: NUNCA desabilita. Com cache, 2o boot do Firefox e ~40% mais rapido.
  export MESA_SHADER_CACHE_DISABLE=false
  export MESA_SHADER_CACHE_DIR=/root/.cache/olal-shader
  export MESA_GLSL_CACHE_DIR=/root/.cache/olal-shader
  mkdir -p /root/.cache/olal-shader 2>/dev/null
  # heap: menos arenas = menos RAM fragmentada em apps com threads (Firefox, Chromium)
  export MALLOC_ARENA_MAX=2
  # input do Firefox mais responsivo (toque/scroll)
  export MOZ_USE_XINPUT2=1
  # GTK: menos reload de tema, mais rapido pra abrir app
  export GTK_MODULES=""
  export NO_AT_BRIDGE=1

  # ---- WM + barra do Olal ----
  mkdir -p /run/dbus
  # openbox: so gerencia janelas (maximize-all + undecorate via rc.xml).
  # --config-file aponta pro rc.xml do Olal (regras mobile-like).
  # Sem --sm-disable nem --exit-with-session (v8 usava `dbus-launch openbox &`
  # simples; voltamos a isso pra maximizar compatibilidade).
  dbus-launch openbox --config-file /root/.config/openbox/rc.xml &
  sleep 2
  # barra do Olal no topo (botao "Olal" + lista de janelas). Auto-hide apos 2s.
  tint2 -c /root/.config/tint2/tint2rc >/dev/null 2>&1 &
  sleep 1
  # remove qualquer decoracao de janelas que por ventura ja existam (cold-start safety)
  wmctrl -r ":ACTIVE:" -b remove,decorated 2>/dev/null || true

  # ---- interface do Olal em tela cheia (o navegador kiosk) ----
  exec olal-shell
INNER

SESLOG="$TMPDIR/olal-session.log"; rm -f "$SESLOG"
run_session(){
  if [ -f "$HOME/.olal-noseccomp" ]; then
    echo ">> proot em MODO COMPATIVEL (PROOT_NO_SECCOMP=1 - contorna o bug de fork/ENOSYS)."
    PROOT_NO_SECCOMP=1 proot-distro login debian --shared-tmp -- /bin/bash /tmp/olal-inner.sh 2>&1 | tee -a "$SESLOG"
  else
    proot-distro login debian --shared-tmp -- /bin/bash /tmp/olal-inner.sh 2>&1 | tee -a "$SESLOG"
  fi
}
run_session
# BUG DO PROOT (kernels Android novos): fork() devolve ENOSYS e TUDO morre
# ("fork: Function not implemented" / "XIO: fatal IO error 38"). Se detectado,
# ativa o modo compativel PERMANENTEMENTE e reinicia a sessao AGORA.
if [ ! -f "$HOME/.olal-noseccomp" ] && \
   grep -qiE "Function not implemented|fatal IO error 38" "$SESLOG" 2>/dev/null; then
  echo ""
  echo ">> !! BUG DO PROOT DETECTADO (fork/ENOSYS - comum apos update do Android)."
  echo ">> Ativando modo compativel e reiniciando o Olal automaticamente..."
  touch "$HOME/.olal-noseccomp"
  ( yes | timeout 90 pkg install proot >/dev/null 2>&1 ) || true   # tenta proot corrigido
  pkill -f "termux-x11 :0" 2>/dev/null; termux-x11 :0 >/dev/null 2>&1 &
  sleep 2
  run_session
fi

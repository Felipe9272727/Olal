#!/data/data/com.termux/files/usr/bin/bash
# ============================================================
#  Olal OS - inicia o desktop Debian XFCE no Termux:X11 com
#  GPU REAL da Adreno (virgl p/ o desktop, Turnip/zink p/ apps).
#  Metodo comprovado (phoenixbyrd/Termux_XFCE), adaptado.
# ============================================================

# 1) audio (PulseAudio sobre TCP -> YouTube com som)
pulseaudio --start \
  --load="module-native-protocol-tcp auth-ip-acl=127.0.0.1 auth-anonymous=1" \
  --exit-idle-time=-1 2>/dev/null || true

# 2) servidor GPU virtual (virgl) -- env da Adreno; TEM que subir ANTES do X
pkill -f virgl_test_server 2>/dev/null
MESA_NO_ERROR=1 MESA_GL_VERSION_OVERRIDE=4.3COMPAT \
MESA_GLES_VERSION_OVERRIDE=3.2 LIBGL_DRI3_DISABLE=1 \
  virgl_test_server_android >/dev/null 2>&1 &

# 3) servidor de tela (Termux:X11)
pkill -f "termux-x11 :0" 2>/dev/null
export XDG_RUNTIME_DIR="$TMPDIR"
termux-x11 :0 >/dev/null 2>&1 &
sleep 3
am start --user 0 -n com.termux.x11/com.termux.x11.MainActivity >/dev/null 2>&1 || true
sleep 1

echo ">> Abra o app Termux:X11 para ver o desktop do Olal."

# 4) desktop XFCE dentro do Debian (virpipe), com audio e dbus
proot-distro login debian --shared-tmp -- /bin/bash -c '
  export DISPLAY=:0
  export PULSE_SERVER=127.0.0.1
  export GALLIUM_DRIVER=virpipe
  export MESA_GL_VERSION_OVERRIDE=4.3COMPAT
  export MESA_GLES_VERSION_OVERRIDE=3.2
  export MESA_NO_ERROR=1
  mkdir -p /run/dbus
  dbus-launch --exit-with-session xfce4-session
'

#!/data/data/com.termux/files/usr/bin/bash
# ============================================================
#  Olal OS - boota DIRETO na interface do Olal (o OS em si),
#  rodando sobre o Debian, no Termux:X11, com GPU da Adreno.
#  A interface do Olal E o sistema - nao e um launcher.
# ============================================================

# 0) AUTO-ATUALIZA do GitHub e PREPARA o deploy num /tmp compartilhado.
#    Em vez de adivinhar o caminho do rootfs do Debian (que varia e fazia a
#    copia falhar calada), a gente poe os arquivos no $TMPDIR e copia de DENTRO
#    do proot (onde /tmp e sempre o lugar certo). A prova de bala.
SRC="$HOME/Olal"
DEPLOY="$TMPDIR/olal-deploy"
( if [ -d "$SRC/.git" ]; then
    echo ">> Procurando atualizacoes do Olal OS..."
    if ( cd "$SRC" && timeout 30 git fetch origin main >/dev/null 2>&1 \
          && git reset --hard origin/main >/dev/null 2>&1 ); then
      echo ">> Atualizado para: $(cd "$SRC" && git log -1 --format='%h %s' 2>/dev/null)"
    else
      echo "!! Nao consegui baixar a atualizacao (rede/VPN?). Usando a versao local."
      echo "   Dica: desligue a VPN e rode de novo, ela bloqueia o GitHub."
    fi
  fi ) || true
# stage dos arquivos no /tmp compartilhado (sempre visivel dentro do proot)
rm -rf "$DEPLOY" 2>/dev/null; mkdir -p "$DEPLOY"
cp -rf "$SRC/olal-os/shell"           "$DEPLOY/shell"      2>/dev/null
cp -f  "$SRC/olal-os/desktop/olal-shell" "$DEPLOY/olal-shell" 2>/dev/null
grep -o 'OLAL_BUILD = "[^"]*"' "$DEPLOY/shell/index.html" 2>/dev/null \
  | sed 's/OLAL_BUILD = />> Versao que vai ser instalada: /'
# cinto-e-suspensorio: tambem tenta copiar direto pro rootfs (varios caminhos
# possiveis do proot-distro). Se um bater, ja atualiza; senao, o /tmp resolve.
for RD in \
  "$PREFIX/var/lib/proot-distro/installed-rootfs/debian" \
  "$HOME/.proot-distro/installed-rootfs/debian" \
  /data/data/com.termux/files/usr/var/lib/proot-distro/installed-rootfs/debian; do
  if [ -d "$RD" ]; then
    mkdir -p "$RD/opt/olal/shell" 2>/dev/null
    cp -rf "$DEPLOY/shell/." "$RD/opt/olal/shell/" 2>/dev/null \
      && cp -f "$DEPLOY/olal-shell" "$RD/usr/local/bin/olal-shell" 2>/dev/null \
      && chmod +x "$RD/usr/local/bin/olal-shell" 2>/dev/null \
      && echo ">> (copia direta ok em $RD)"
  fi
done

# 1) audio (PulseAudio sobre TCP -> YouTube com som)
pulseaudio --start \
  --load="module-native-protocol-tcp auth-ip-acl=127.0.0.1 auth-anonymous=1" \
  --exit-idle-time=-1 2>/dev/null || true

# 2) servidor GPU (virgl) ACELERADO POR HARDWARE -- TEM que subir ANTES do X.
#    Tenta a variante zink->Turnip (GPU real da Adreno), que acelera TODO o
#    desktop (inclusive o Firefox). Se ela nao existir, cai pro virgl_test_server
#    _android (software) - exatamente o comportamento antigo, sem regressao.
pkill -f virgl_test_server 2>/dev/null
rm -f "$TMPDIR/olal-gpu" 2>/dev/null   # flag: GPU acelerada esta ativa?
if command -v virgl_test_server >/dev/null 2>&1; then
  echo ">> GPU: virgl acelerado por zink/Turnip (Adreno)."
  MESA_LOADER_DRIVER_OVERRIDE=zink GALLIUM_DRIVER=zink ZINK_DESCRIPTORS=lazy \
  MESA_NO_ERROR=1 MESA_GL_VERSION_OVERRIDE=4.3COMPAT MESA_GLES_VERSION_OVERRIDE=3.2 \
    virgl_test_server --use-egl-surfaceless >/dev/null 2>&1 &
  # avisa o olal-shell (via /tmp compartilhado) que a GPU acelerada esta no ar,
  # pra ele so entao tentar os navegadores por GPU (senao fica no Firefox SW).
  touch "$TMPDIR/olal-gpu" 2>/dev/null
else
  echo ">> GPU: virgl (software) -- instale virglrenderer-mesa-zink p/ acelerar."
  MESA_NO_ERROR=1 MESA_GL_VERSION_OVERRIDE=4.3COMPAT \
  MESA_GLES_VERSION_OVERRIDE=3.2 LIBGL_DRI3_DISABLE=1 \
    virgl_test_server_android >/dev/null 2>&1 &
fi

# 3) servidor de tela (Termux:X11)
pkill -f "termux-x11 :0" 2>/dev/null
export XDG_RUNTIME_DIR="$TMPDIR"
termux-x11 :0 >/dev/null 2>&1 &
sleep 3
am start --user 0 -n com.termux.x11/com.termux.x11.MainActivity >/dev/null 2>&1 || true
sleep 1

# prioridade: rebaixa os servicos de fundo (virgl/pulseaudio) pra o NAVEGADOR
# ganhar CPU. renice pra valor positivo (menor prioridade) e permitido sem root.
for p in virgl_test_server virgl_test_server_android pulseaudio; do
  pgrep -x "$p" >/dev/null 2>&1 && renice +5 -p $(pgrep -x "$p") >/dev/null 2>&1
done

echo ">> Abra o app Termux:X11 para ver o Olal OS."

# 4) BOOTA o Olal OS: instala o codigo novo (de DENTRO, via /tmp compartilhado),
#    sobe o WM minimo (openbox) e a interface do Olal em tela cheia.
#    A interface (com terminal/arquivos/sistema REAIS via backend) E o OS.
proot-distro login debian --shared-tmp -- /bin/bash -c '
  # instala o codigo novo que o Termux deixou em /tmp/olal-deploy (caminho certo
  # SEMPRE, visto de dentro do proot - nada de adivinhar o rootfs)
  if [ -d /tmp/olal-deploy/shell ]; then
    mkdir -p /opt/olal/shell
    cp -rf /tmp/olal-deploy/shell/. /opt/olal/shell/
    [ -f /tmp/olal-deploy/olal-shell ] && cp -f /tmp/olal-deploy/olal-shell /usr/local/bin/olal-shell && chmod +x /usr/local/bin/olal-shell
    echo ">> Olal OS instalado dentro do Debian:"
    grep -o "OLAL_BUILD = \"[^\"]*\"" /opt/olal/shell/index.html 2>/dev/null | sed "s/OLAL_BUILD = />>   versao: /"
  fi
  # ---- tuning do sistema (idempotente, barato): apt/dpkg mais rapido e leve ----
  if [ ! -f /etc/apt/apt.conf.d/99olal ]; then
    printf "APT::Install-Recommends \"false\";\nAPT::Install-Suggests \"false\";\nAcquire::Languages \"none\";\n" > /etc/apt/apt.conf.d/99olal 2>/dev/null
  fi
  if [ ! -f /etc/dpkg/dpkg.cfg.d/99olal-nodoc ]; then
    printf "path-exclude /usr/share/doc/*\npath-exclude /usr/share/man/*\npath-exclude /usr/share/info/*\npath-exclude /usr/share/locale/*/LC_MESSAGES/*.mo\n" > /etc/dpkg/dpkg.cfg.d/99olal-nodoc 2>/dev/null
  fi
  export DISPLAY=:0
  export PULSE_SERVER=127.0.0.1
  export GALLIUM_DRIVER=virpipe
  export MESA_GL_VERSION_OVERRIDE=4.3COMPAT
  export MESA_GLES_VERSION_OVERRIDE=3.2
  export MESA_NO_ERROR=1
  export MALLOC_ARENA_MAX=2        # menos fragmentacao/CPU de heap em apps com threads
  export MOZ_USE_XINPUT2=1         # input do Firefox mais responsivo (toque/scroll)
  mkdir -p /run/dbus
  dbus-launch openbox &
  sleep 2
  exec olal-shell
'

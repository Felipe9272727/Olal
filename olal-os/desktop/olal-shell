#!/bin/bash
# Abre a interface do Olal (a IA + apps) no navegador do desktop.
# Padrao: Firefox (renderiza pelo mesmo caminho GTK/X11 do desktop, que
# funciona). Alternativa: 'olal-shell chromium' usa o Chromium via zink/Turnip.
pkill -f "http.server 8080" 2>/dev/null
( cd /opt/olal/shell && python3 -m http.server 8080 >/dev/null 2>&1 & )
sleep 1
URL="http://localhost:8080/index.html"

if [ "$1" = "chromium" ] && command -v chromium >/dev/null 2>&1; then
  # Chromium com GPU real da Adreno (Turnip via zink)
  exec env MESA_LOADER_DRIVER_OVERRIDE=zink TU_DEBUG=noconform \
    chromium --no-sandbox --kiosk --ozone-platform=x11 \
    --enable-features=UseOzonePlatform --use-gl=egl \
    --autoplay-policy=no-user-gesture-required \
    --user-data-dir="$HOME/.olal-chrome" "$URL"
fi

if command -v firefox-esr >/dev/null 2>&1; then
  export MOZ_FAKE_NO_SANDBOX=1 MOZ_DISABLE_RDD_SANDBOX=1
  exec firefox-esr --kiosk "$URL"
elif command -v firefox >/dev/null 2>&1; then
  export MOZ_FAKE_NO_SANDBOX=1
  exec firefox --kiosk "$URL"
elif command -v chromium >/dev/null 2>&1; then
  exec env MESA_LOADER_DRIVER_OVERRIDE=zink TU_DEBUG=noconform \
    chromium --no-sandbox --kiosk --ozone-platform=x11 --use-gl=egl \
    --user-data-dir="$HOME/.olal-chrome" "$URL"
else
  echo "Nenhum navegador instalado. Rode: apt install firefox-esr"
fi

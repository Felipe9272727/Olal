#!/bin/bash
# ============================================================
#  Olal OS - interface do sistema (a "cara" do OS) em tela cheia.
#  Sobe o backend (terminal/arquivos/sistema reais) e abre a
#  interface no 1o navegador que RENDERIZAR (firefox -> chromium).
# ============================================================
pkill -f "olal/shell/backend.py" 2>/dev/null
( cd /opt/olal/shell && OLAL_PORT=8080 python3 backend.py >/dev/null 2>&1 & )
sleep 1
URL="http://localhost:8080/index.html"

# perfil do Firefox: vai DIRETO pra interface, sem telas de boas-vindas/dialogs
PROF="$HOME/.olal-ff"; mkdir -p "$PROF"
cat > "$PROF/user.js" <<'JS'
user_pref("browser.shell.checkDefaultBrowser", false);
user_pref("browser.aboutwelcome.enabled", false);
user_pref("browser.startup.firstrunSkipsHomepage", true);
user_pref("datareporting.policy.dataSubmissionEnabled", false);
user_pref("toolkit.telemetry.reportingpolicy.firstRun", false);
user_pref("browser.tabs.warnOnClose", false);
user_pref("browser.warnOnQuit", false);
user_pref("media.autoplay.default", 0);
user_pref("media.autoplay.blocking_policy", 0);
JS

# tenta um navegador; se ele cair em <6s (crash/tela preta), volta e tenta o proximo
try(){ "$@" >/dev/null 2>&1 & local pid=$!; sleep 6
  if kill -0 "$pid" 2>/dev/null; then echo ">> Olal OS rodando."; wait "$pid"; return 0; fi
  return 1; }

export MOZ_FAKE_NO_SANDBOX=1 MOZ_DISABLE_RDD_SANDBOX=1

# 1) Firefox (caminho GTK/software - o mais confiavel no Termux:X11)
command -v firefox-esr >/dev/null && try firefox-esr --kiosk --profile "$PROF" --no-remote "$URL" && exit 0
command -v firefox     >/dev/null && try firefox     --kiosk --profile "$PROF" --no-remote "$URL" && exit 0
# 2) Chromium acelerado por zink/Turnip (GPU real da Adreno)
command -v chromium >/dev/null && try env MESA_LOADER_DRIVER_OVERRIDE=zink TU_DEBUG=noconform \
  chromium --no-sandbox --kiosk --ozone-platform=x11 --enable-features=UseOzonePlatform \
  --use-gl=egl --autoplay-policy=no-user-gesture-required \
  --user-data-dir="$HOME/.olal-chrome" "$URL" && exit 0
# 3) Chromium em processo unico (ultimo recurso)
command -v chromium >/dev/null && try chromium --no-sandbox --kiosk --single-process \
  --ozone-platform=x11 --use-gl=swiftshader --enable-unsafe-swiftshader \
  --user-data-dir="$HOME/.olal-chrome2" "$URL" && exit 0

echo "Nenhum navegador renderizou. Rode 'olal-doctor' para diagnosticar."

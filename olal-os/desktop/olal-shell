#!/bin/bash
# serve a interface do Olal e abre no navegador do desktop
pkill -f "http.server 8080" 2>/dev/null
( cd /opt/olal/shell && python3 -m http.server 8080 >/dev/null 2>&1 & )
sleep 1
# navegador: preenchido pelo setup (firefox-esr com as env certas)
exec "$OLAL_BROWSER" http://localhost:8080/index.html

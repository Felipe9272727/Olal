#!/bin/bash
# ============================================================
#  Olal OS - interface do sistema (a "cara" do OS) em tela cheia.
#  Soba o backend (terminal/arquivos/sistema reais) e abre a
#  interface no 1o navegador que RENDERIZAR (firefox -> chromium).
#
#  ARQUITETURA:
#  - O navegador do Olal abre em modo --kiosk (tela cheia REAL,
#    sem URL bar, sem tabs, sem decoração). E a interface do OS.
#  - Apps baixados (GIMP, LibreOffice, etc.) abrem como janelas
#    MAXIMIZADAS SEM DECORACAO via regras do openbox (rc.xml).
#  - A barra do Olal (tint2, 28px no topo) fica ACIMA do navegador
#    kiosk NAO - kiosk cobre tudo. Em vez disso, o navegador do
#    Olal deixa 28px no topo (via --window-size + --window-position
#    no Chromium, ou via JS no Firefox). A barra do Olal fica visivel.
#  - Apps baixados abrem "por cima" do navegador; o botao "Olal"
#    da barra traz o navegador de volta pra frente.
#
#  Em caso de GPU quebrada (tela preta), cai automaticamente pro
#  Firefox por software (caminho garantido).
# ============================================================
# auto-atualiza a interface do GitHub (best-effort; nao trava se offline/VPN)
mkdir -p /opt/olal/shell
B="https://raw.githubusercontent.com/Felipe9272727/Olal/main/olal-os/shell"
for f in index.html backend.py model.js; do
  if timeout 12 curl -fsSL "$B/$f" -o "/opt/olal/shell/$f.new" 2>/dev/null && [ -s "/opt/olal/shell/$f.new" ]; then
    mv "/opt/olal/shell/$f.new" "/opt/olal/shell/$f"; echo ">> interface: $f atualizado do GitHub"
  else rm -f "/opt/olal/shell/$f.new"; fi
done
# AUTO-CURA: atualiza a si mesmo (o launcher) do GitHub. Assim, mesmo que a
# copia do Termux pro Debian falhe, o olal-shell se conserta no proximo boot.
SELF="https://raw.githubusercontent.com/Felipe9272727/Olal/main/olal-os/desktop/olal-shell"
if timeout 12 curl -fsSL "$SELF" -o "/usr/local/bin/olal-shell.new" 2>/dev/null && [ -s "/usr/local/bin/olal-shell.new" ]; then
  if ! cmp -s "/usr/local/bin/olal-shell.new" "/usr/local/bin/olal-shell"; then
    mv "/usr/local/bin/olal-shell.new" "/usr/local/bin/olal-shell"; chmod +x /usr/local/bin/olal-shell
    echo ">> launcher atualizado - reiniciando com a versao nova..."; exec /usr/local/bin/olal-shell "$@"
  else rm -f "/usr/local/bin/olal-shell.new"; fi
else rm -f "/usr/local/bin/olal-shell.new"; fi
# AUTO-CURA do shell nativo (olal-webkit) tambem
WKURL="https://raw.githubusercontent.com/Felipe9272727/Olal/main/olal-os/desktop/olal-webkit"
if timeout 12 curl -fsSL "$WKURL" -o "/usr/local/bin/olal-webkit.new" 2>/dev/null && [ -s "/usr/local/bin/olal-webkit.new" ]; then
  mv "/usr/local/bin/olal-webkit.new" "/usr/local/bin/olal-webkit"; chmod +x /usr/local/bin/olal-webkit
else rm -f "/usr/local/bin/olal-webkit.new"; fi
grep -o 'OLAL_BUILD = "[^"]*"' /opt/olal/shell/index.html 2>/dev/null | sed 's/OLAL_BUILD = />> versao da interface: /'
pkill -f "olal/shell/backend.py" 2>/dev/null
( cd /opt/olal/shell && OLAL_PORT=8080 python3 backend.py >/dev/null 2>&1 & )
sleep 1
# limpa o cache do Firefox a cada boot (garante que nunca prende em versao velha)
rm -rf "$HOME/.olal-ff/cache2" "$HOME/.cache/mozilla" 2>/dev/null
# cache-buster: forca o Firefox a carregar a versao nova (nunca do cache)
URL="http://localhost:8080/index.html?v=$(date +%s)"

# perfil do Firefox: vai DIRETO pra interface, sem telas de boas-vindas/dialogs
PROF="$HOME/.olal-ff"; mkdir -p "$PROF"
cat > "$PROF/user.js" <<'JS'
user_pref("browser.shell.checkDefaultBrowser", false);
user_pref("browser.aboutwelcome.enabled", false);
user_pref("browser.startup.firstrunSkipsHomepage", true);
user_pref("datareporting.policy.dataSubmissionEnabled", false);
user_pref("toolkit.telemetry.reportingpolicy.firstRun", false);
user_pref("browser.tabs.warnOnClose", false);
user_pref("browser.warnOnQuit", false);
user_pref("media.autoplay.default", 0);
user_pref("media.autoplay.blocking_policy", 0);
user_pref("browser.cache.disk.enable", false);
user_pref("browser.cache.memory.enable", false);
user_pref("browser.cache.offline.enable", false);
/* PERF (kiosk): menos CPU/RAM sem mudar a aparencia */
user_pref("accessibility.force_disabled", 1);        /* desliga o motor de a11y (ganho real de CPU) */
user_pref("dom.ipc.processCount", 1);                /* 1 processo de conteudo (so 1 pagina) */
user_pref("browser.sessionstore.interval", 600000);  /* quase nao salva sessao (menos I/O) */
user_pref("browser.sessionstore.resume_from_crash", false);
user_pref("extensions.pocket.enabled", false);
user_pref("reader.parse-on-load.enabled", false);
user_pref("browser.newtabpage.enabled", false);
user_pref("toolkit.telemetry.enabled", false);
user_pref("datareporting.healthreport.uploadEnabled", false);
user_pref("network.prefetch-next", false);
/* CORRECAO DA TELA PRETA: a outra IA forcou WebRender por HARDWARE
   (gfx.webrender.all=true) - isso pinta a tela uma vez e vai pra PRETO num
   GL instavel (Termux:X11). REMOVIDO. Em vez disso, forca WebRender por
   SOFTWARE: renderiza de forma confiavel (era o caminho que funcionava),
   sem depender da GPU. A GPU continua sendo usada pelos tiers de GPU
   (Chromium/WebKit), com detector de tela preta. */
user_pref("gfx.webrender.software", true);           /* WebRender por CPU = confiavel, nunca tela preta */
user_pref("gfx.webrender.force-disabled", false);
user_pref("dom.ipc.plugins.asyncInit", true);
user_pref("dom.ipc.processPrelaunch.enabled", false);
JS

# ============================================================
#  Escolha do navegador com ACELERACAO POR GPU (Adreno/Turnip) e
#  rede de seguranca: se a tela ficar PRETA (GPU falhou), cai sozinho
#  pro Firefox por software (o caminho garantido).
#
#  VOLTOU --kiosk: a interface do Olal E kiosk (tela cheia, sem UI
#  do navegador). A barra do Olal (tint2) aparece ACIMA do kiosk
#  porque o openbox tem <layer>above</layer> pra tint2 no rc.xml.
#  Apps baixados abrem por cima do kiosk (maximizados, sem decoracao).
# ============================================================
export DISPLAY="${DISPLAY:-:0}"
export MOZ_FAKE_NO_SANDBOX=1 MOZ_DISABLE_RDD_SANDBOX=1
GPU_ON=0; [ -f /tmp/olal-gpu ] && GPU_ON=1

# detector de tela preta: captura a raiz do X e mede o brilho medio (0-255).
# UI do Olal tem fundo/icones coloridos -> brilho alto; GPU quebrada -> ~0.
HAVE_SHOT=0; command -v import >/dev/null && command -v convert >/dev/null && HAVE_SHOT=1
[ "$HAVE_SHOT" = 0 ] && ( apt-get install -y imagemagick >/dev/null 2>&1 \
  || sudo apt-get install -y imagemagick >/dev/null 2>&1 ) &
screen_bright(){ import -window root -silent /tmp/olal-probe.png 2>/dev/null \
  && convert /tmp/olal-probe.png -colorspace Gray -resize 1x1 -format '%[fx:int(mean*255)]' info: 2>/dev/null; }

# roda um navegador e confirma que RENDEROU (processo vivo + tela nao-preta).
# $1 = rotulo; resto = comando. Retorna 0 e segura o processo se renderizou.
run_browser(){ local label="$1"; shift
  echo ">> tentando: $label"
  "$@" >/dev/null 2>&1 & local pid=$!
  local t=0 ok=0
  while [ $t -lt 12 ]; do sleep 1; t=$((t+1))
    kill -0 "$pid" 2>/dev/null || { echo "   ($label caiu)"; return 1; }
    if [ $t -ge 6 ] && [ "$HAVE_SHOT" = 1 ]; then
      local b; b=$(screen_bright)
      if [ -n "$b" ] && [ "$b" -gt 10 ] 2>/dev/null; then ok=1; break; fi
    fi
  done
  [ "$HAVE_SHOT" = 1 ] || { kill -0 "$pid" 2>/dev/null && ok=1; }
  if [ "$ok" = 1 ]; then echo ">> Olal OS rodando ($label, render OK)."; wait "$pid"; return 0; fi
  echo "   ($label nao renderizou - tela preta? proximo...)"
  kill "$pid" 2>/dev/null; pkill -P "$pid" 2>/dev/null; sleep 1; return 1; }

# ---- env de GPU: Turnip (Vulkan da Adreno) via zink, acesso direto ao KGSL ----
ARCH="$(uname -m)"
ICD="/usr/share/vulkan/icd.d/freedreno_icd.${ARCH}.json"
mkdir -p "$HOME/.cache/olal-shader"
GPU_ENV=(MESA_LOADER_DRIVER_OVERRIDE=zink TU_DEBUG=noconform vblank_mode=0
  MESA_SHADER_CACHE_DISABLE=false "MESA_SHADER_CACHE_DIR=$HOME/.cache/olal-shader"
  "MESA_GLSL_CACHE_DIR=$HOME/.cache/olal-shader"
  MESA_GL_VERSION_OVERRIDE=4.3COMPAT MESA_GLES_VERSION_OVERRIDE=3.2 MESA_NO_ERROR=1)
[ -f "$ICD" ] && GPU_ENV+=("VK_ICD_FILENAMES=$ICD")

# ---- RENDER SCALE: rasteriza em menos pixels (a CPU/GPU desenha menos) e o
#      compositor da o upscale. MEDIDO ~2.5x mais rapido a 0.6-0.7. NAO mexe no
#      tamanho da janela nem no toque (innerWidth fica igual) - so a nitidez cai
#      um tico. Ajuste/desligue com OLAL_RENDER_SCALE (1 = nativo, sem reducao).
RSCALE="${OLAL_RENDER_SCALE:-0.7}"
DSF_FLAG=""; case "$RSCALE" in 1|1.0|1.00) ;; *) DSF_FLAG="--force-device-scale-factor=$RSCALE";; esac

# OPCIONAL (faz o FIREFOX tambem ganhar): reduz a resolucao do X inteiro via
# xrandr. OFF por padrao - em alguns aparelhos pode bagunçar geometria/toque.
# Ligar com:  export OLAL_XSCALE=0.8   (antes do ./olal). Verifica e reverte
# se o X nao responder. Quando ligado, zera o DSF do Chromium (evita reduzir 2x).
if [ -n "$OLAL_XSCALE" ] && command -v xrandr >/dev/null 2>&1; then
  XOUT=$(xrandr -q 2>/dev/null | awk '/ connected/{print $1; exit}')
  if [ -n "$XOUT" ] && xrandr --output "$XOUT" --scale "${OLAL_XSCALE}x${OLAL_XSCALE}" 2>/dev/null; then
    if xdpyinfo >/dev/null 2>&1; then echo ">> X render-scale ${OLAL_XSCALE}x ativo (Firefox tambem mais fluido)."; DSF_FLAG="";
    else xrandr --output "$XOUT" --scale 1x1 2>/dev/null; echo ">> xrandr revertido (X nao respondeu)."; fi
  fi
fi

# ============================================================
#  SHELL NATIVO (olal-webkit): a UI E o sistema, NAO um navegador.
#  E o caminho preferido. Usa o mesmo render GTK/X11 do Firefox (confiavel),
#  porem e um app do PROPRIO Olal (janela "Olal OS"), mais leve, com toque
#  nativo. Os navegadores abaixo ficam so como ULTIMO recurso.
# ============================================================
have_webkit(){ python3 -c "import gi; gi.require_version('Gtk','3.0')
for v in ('4.1','4.0','6.0'):
 try: gi.require_version('WebKit2',v); raise SystemExit(0)
 except ValueError: pass
try: gi.require_version('WebKit',v)
except Exception: raise SystemExit(1)" 2>/dev/null; }
WK=/usr/local/bin/olal-webkit
if [ -x "$WK" ] && have_webkit; then
  # 0a) shell nativo por GPU - SO com o detector de tela preta ativo (senao
  #     uma falha de GPU ficaria presa em preto sem ser detectada).
  if [ "$GPU_ON" = 1 ] && [ "$HAVE_SHOT" = 1 ]; then
    run_browser "Olal nativo (WebKit GPU)" env "${GPU_ENV[@]}" OLAL_WK_GPU=1 \
      python3 "$WK" "$URL" && exit 0
  fi
  # 0b) shell nativo por software (CONFIAVEL - exatamente a config testada que
  #     renderiza: compositing desligado + GL por software = sem GPU = sem tela
  #     preta. E o caminho preferido pra UI nativa.)
  run_browser "Olal nativo (WebKit)" env WEBKIT_DISABLE_COMPOSITING_MODE=1 LIBGL_ALWAYS_SOFTWARE=1 \
    python3 "$WK" "$URL" && exit 0
else
  # webkit ausente: instala em 2o plano pro proximo boot virar nativo (4.1 ou 4.0)
  ( for pk in "python3-gi gir1.2-webkit2-4.1 libwebkit2gtk-4.1-0" \
              "python3-gi gir1.2-webkit2-4.0 libwebkit2gtk-4.0-37"; do
      apt-get install -y $pk >/dev/null 2>&1 && break
    done ) &
  echo ">> shell nativo (WebKit) sera instalado; por ora uso o navegador."
fi

# 1) CHROMIUM acelerado por GPU (Turnip/zink) - ultimo recurso (navegador).
#    --kiosk: tela cheia, sem URL bar, sem tabs. Interface do Olal em tela cheia.
if [ "$GPU_ON" = 1 ] && [ "$HAVE_SHOT" = 1 ] && command -v chromium >/dev/null; then
  run_browser "Chromium GPU (Turnip/zink, render ${RSCALE}x)" env "${GPU_ENV[@]}" \
    chromium --no-sandbox --kiosk --ozone-platform=x11 --enable-features=UseOzonePlatform,VaapiVideoDecoder \
    --use-gl=egl --ignore-gpu-blocklist --enable-gpu-rasterization --enable-zero-copy \
    --canvas-oop-rasterization --autoplay-policy=no-user-gesture-required $DSF_FLAG \
    --disable-background-timer-throttling --no-first-run --disable-sync --disable-translate \
    --disable-extensions --disable-component-update --user-data-dir="$HOME/.olal-chrome" "$URL" && exit 0
fi
# 2) FIREFOX com WebRender por GPU (usa o virgl acelerado por zink/Turnip).
FF=""; command -v firefox-esr >/dev/null && FF=firefox-esr || { command -v firefox >/dev/null && FF=firefox; }
if [ -n "$FF" ] && [ "$GPU_ON" = 1 ] && [ "$HAVE_SHOT" = 1 ]; then
  run_browser "Firefox GPU (WebRender/virgl)" \
    env MOZ_WEBRENDER=1 MOZ_X11_EGL=1 MOZ_ACCELERATED=1 LIBGL_ALWAYS_SOFTWARE=0 \
    "$FF" --kiosk --profile "$PROF" --no-remote "$URL" && exit 0
fi
# 3) FIREFOX por software - o caminho GARANTIDO (identico ao que ja funcionava)
[ -n "$FF" ] && run_browser "Firefox (software)" \
  "$FF" --kiosk --profile "$PROF" --no-remote "$URL" && exit 0
# 4) CHROMIUM swiftshader em processo unico (ultimo recurso)
command -v chromium >/dev/null && run_browser "Chromium swiftshader (render ${RSCALE}x)" \
  chromium --no-sandbox --kiosk --single-process --ozone-platform=x11 \
  --use-gl=swiftshader --enable-unsafe-swiftshader $DSF_FLAG \
  --user-data-dir="$HOME/.olal-chrome2" "$URL" && exit 0

echo "Nenhum navegador renderizou. Rode 'olal-doctor' para diagnosticar."

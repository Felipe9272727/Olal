#!/data/data/com.termux/files/usr/bin/bash
# ============================================================
#  Olal OS - diagnostico. Diz EXATAMENTE onde a atualizacao para,
#  sem adivinhacao. Rode no Termux:  bash ~/Olal/olal-os/olal-doctor
# ============================================================
SRC="$HOME/Olal"
RAW="https://raw.githubusercontent.com/Felipe9272727/Olal/main/olal-os/shell/index.html"
ok(){ printf '  \033[32mOK\033[0m  %s\n' "$1"; }
bad(){ printf '  \033[31mXX\033[0m  %s\n' "$1"; }
hr(){ printf '\n\033[1m== %s ==\033[0m\n' "$1"; }

hr "1) Clone do Olal no Termux ($SRC)"
if [ -d "$SRC/.git" ]; then
  ok "repositorio encontrado"
  echo "     commit local: $(cd "$SRC" && git log -1 --format='%h %s' 2>/dev/null)"
  v=$(grep -o 'OLAL_BUILD = "[^"]*"' "$SRC/olal-os/shell/index.html" 2>/dev/null)
  [ -n "$v" ] && ok "versao no clone: $v" || bad "sem OLAL_BUILD no clone (clone velho? rode: git reset --hard origin/main)"
  grep -q 'App Store' "$SRC/olal-os/shell/index.html" 2>/dev/null && ok "App Store presente no clone" || bad "App Store AUSENTE no clone"
  # valida se a versao NOVA (apps integrados) chegou no clone
  grep -q 'wbadge\|winmgr\|launch_integrated' "$SRC/olal-os/shell/index.html" 2>/dev/null \
    && ok "gerenciador de janelas (apps integrados) presente" \
    || bad "gerenciador de janelas AUSENTE (clone velho - rode: cd ~/Olal && git reset --hard origin/main)"
  [ -f "$SRC/olal-os/desktop/olal-rc.xml" ] && ok "config do openbox (maximize-all) presente" || bad "olal-rc.xml ausente"
  [ -f "$SRC/olal-os/desktop/olal-tint2rc" ] && ok "config da barra do Olal (tint2) presente" || bad "olal-tint2rc ausente"
else
  bad "nao achei o repo em $SRC (rode o install)"
fi

hr "2) Rede ate o GitHub"
if timeout 15 git -C "$SRC" ls-remote origin -h refs/heads/main >/dev/null 2>&1; then
  ok "git alcanca o GitHub (origin/main: $(git -C "$SRC" rev-parse --short origin/main 2>/dev/null))"
else
  bad "git NAO alcanca o GitHub -> VPN/rede. Desligue a VPN."
fi
if timeout 15 curl -fsSL "$RAW" -o /dev/null 2>/dev/null; then
  ok "curl alcanca raw.githubusercontent.com (auto-update da interface funciona)"
else
  bad "curl NAO alcanca raw.githubusercontent.com -> VPN/filtro bloqueando o raw"
fi

hr "3) Onde o Debian esta instalado (rootfs)"
FOUND=0
for RD in \
  "$PREFIX/var/lib/proot-distro/installed-rootfs/debian" \
  "$HOME/.proot-distro/installed-rootfs/debian" \
  /data/data/com.termux/files/usr/var/lib/proot-distro/installed-rootfs/debian; do
  if [ -d "$RD" ]; then
    FOUND=1; ok "rootfs: $RD"
    if [ -f "$RD/opt/olal/shell/index.html" ]; then
      iv=$(grep -o 'OLAL_BUILD = "[^"]*"' "$RD/opt/olal/shell/index.html" 2>/dev/null)
      [ -n "$iv" ] && ok "    versao INSTALADA no Debian: $iv" || bad "    Debian tem index.html mas SEM build stamp (versao velha)"
      grep -q 'wbadge\|winmgr' "$RD/opt/olal/shell/index.html" 2>/dev/null \
        && ok "    gerenciador de janelas INSTALADO no Debian" \
        || bad "    gerenciador de janelas AUSENTE no Debian (rodar ./olal)"
      grep -q 'App Store' "$RD/opt/olal/shell/index.html" 2>/dev/null && ok "    App Store presente no Debian" || bad "    App Store AUSENTE no Debian (codigo velho)"
    else
      bad "    sem /opt/olal/shell/index.html no Debian (interface nao instalada)"
    fi
    if [ -f "$RD/usr/local/bin/olal-shell" ]; then
      grep -q 'AUTO-CURA' "$RD/usr/local/bin/olal-shell" 2>/dev/null && ok "    olal-shell tem auto-cura (novo)" || bad "    olal-shell e ANTIGO (sem auto-cura/cache-buster)"
    else
      bad "    sem /usr/local/bin/olal-shell no Debian"
    fi
    # ---- SHELL NATIVO: a UI E o sistema (WebKit), nao um navegador ----
    [ -x "$RD/usr/local/bin/olal-webkit" ] && ok "    shell NATIVO (olal-webkit) instalado" || bad "    shell nativo AUSENTE (vai usar navegador; rode ./olal)"
    [ -x "$RD/usr/bin/python3" ] && [ -e "$RD/usr/lib/x86_64-linux-gnu/girepository-1.0/WebKit2-4.1.typelib" -o -e "$RD/usr/lib/aarch64-linux-gnu/girepository-1.0/WebKit2-4.1.typelib" -o -e "$RD/usr/lib/aarch64-linux-gnu/girepository-1.0/WebKit2-4.0.typelib" ] \
      && ok "    WebKitGTK presente (UI roda NATIVA, sem Firefox)" \
      || bad "    WebKitGTK ausente (instalando em 2o plano; vira nativo no proximo boot)"
    # ---- checagens novas: integracao de apps (WM + barra + wmctrl) ----
    [ -f "$RD/root/.config/openbox/rc.xml" ] && ok "    openbox config (maximize-all) instalada" || bad "    openbox sem config (apps abrem em janelas, rode ./olal)"
    [ -f "$RD/root/.config/tint2/tint2rc" ] && ok "    barra do Olal (tint2) configurada" || bad "    tint2 sem config (sem botao Olal)"
    [ -f "$RD/usr/local/bin/olal-back" ] && ok "    botao Olal (olal-back) instalado" || bad "    sem olal-back (botao Olal nao funciona)"
    # pacotes de integracao dentro do Debian
    for bin in wmctrl xdotool tint2; do
      [ -x "$RD/usr/bin/$bin" ] && ok "    $bin instalado no Debian" || bad "    $bin AUSENTE (rode setup-desktop.sh de novo)"
    done
  fi
done
[ "$FOUND" = 0 ] && bad "NENHUM rootfs Debian encontrado nos caminhos conhecidos!"

hr "4) Backend da interface (se o Olal estiver aberto)"
if timeout 4 curl -fsS "http://localhost:8080/api/sysinfo" >/dev/null 2>&1; then
  ok "backend respondendo em localhost:8080"
  # testa as rotas novas de integracao de janelas
  if timeout 4 curl -fsS "http://localhost:8080/api/windows" 2>/dev/null | grep -q '"windows"'; then
    ok "rota /api/windows respondendo (gerenciador de janelas OK)"
  else
    bad "rota /api/windows nao respondeu (backend velho - precisa reiniciar o Olal)"
  fi
else
  echo "  (backend nao esta no ar agora - normal se o Olal nao estiver aberto)"
fi

hr "5) Aceleracao por GPU (Adreno/Turnip)"
command -v virgl_test_server >/dev/null 2>&1 \
  && ok "virgl ACELERADO (zink/Turnip) disponivel no Termux" \
  || bad "so virgl software (rode: pkg install mesa-zink virglrenderer-mesa-zink vulkan-loader-android)"
if command -v proot-distro >/dev/null 2>&1; then
  R=$(timeout 25 proot-distro login debian -- bash -lc \
      'MESA_LOADER_DRIVER_OVERRIDE=zink TU_DEBUG=noconform glxinfo 2>/dev/null | grep -i "OpenGL renderer" | head -1' 2>/dev/null)
  if echo "$R" | grep -qi 'zink\|turnip\|adreno'; then ok "navegador usa GPU real: ${R#*: }"
  elif [ -n "$R" ]; then bad "navegador em software: ${R#*: }  (GPU nao engatou)"
  else echo "  (nao deu pra checar o GL agora; abra o Olal e veja 'GPU' no app Sistema)"; fi
fi

hr "6) RELATORIO DOS ULTIMOS BOOTS (o que o Olal tentou e o que aconteceu)"
FOUND_RPT=0
for RD in \
  "$PREFIX/var/lib/proot-distro/installed-rootfs/debian" \
  "$HOME/.proot-distro/installed-rootfs/debian" \
  /data/data/com.termux/files/usr/var/lib/proot-distro/installed-rootfs/debian; do
  if [ -f "$RD/opt/olal/boot-report.txt" ]; then
    FOUND_RPT=1
    tail -14 "$RD/opt/olal/boot-report.txt" | sed 's/^/  /'
    break
  fi
done
[ "$FOUND_RPT" = 0 ] && echo "  (sem relatorio ainda - roda ./olal uma vez que ele grava sozinho)"

hr "7) TESTE DE RENDER HEADLESS (por que o Firefox morre? sem precisar do X)"
if command -v proot-distro >/dev/null 2>&1; then
  echo "  rodando firefox headless dentro do Debian (ate 60s)..."
  HL=$(timeout 90 proot-distro login debian -- bash -lc '
    rm -f /tmp/olal-hl.png
    timeout 60 env -u DISPLAY -u GALLIUM_DRIVER -u MESA_LOADER_DRIVER_OVERRIDE \
      MOZ_FAKE_NO_SANDBOX=1 firefox-esr --headless --screenshot /tmp/olal-hl.png \
      "file:///opt/olal/shell/index.html" 2>&1 | tail -6
    if [ -s /tmp/olal-hl.png ]; then echo "HEADLESS_OK $(stat -c%s /tmp/olal-hl.png)"; else echo "HEADLESS_FALHOU"; fi
  ' 2>/dev/null)
  echo "$HL" | sed 's/^/    /'
  if echo "$HL" | grep -q HEADLESS_OK; then
    ok "o Firefox RENDERIZA a interface no seu aparelho (o problema e X11/WM, nao o navegador)"
  else
    bad "o Firefox NAO renderizou nem headless - as linhas acima dizem o motivo exato"
  fi
else
  echo "  (proot-distro nao encontrado)"
fi

hr "Resumo"
echo "  Se (1) e (2) estao OK mas (3) mostra versao velha no Debian, rode:"
echo "      cd ~/Olal && git reset --hard origin/main && cd olal-os && ./olal"
echo "  O ./olal instala por 3 caminhos; veja as linhas '>> Olal OS instalado dentro do Debian'."
echo ""
echo "  Se (3) mostra 'openbox sem config' ou 'wmctrl AUSENTE', rode o setup-desktop de novo:"
echo "      proot-distro login debian -- bash -c 'bash /root/olal-src/olal-os/setup-desktop.sh'"
